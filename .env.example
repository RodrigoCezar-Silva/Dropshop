# Exemplo de variáveis de ambiente para a API
# Substitua pelos valores reais antes do deploy

PORT=8080
NODE_ENV=production

# Segurança
JWT_SECRET=troque_por_um_valor_secreto_e_longo
CPF_SECRET=troque_por_chave_cpf

# Banco de dados (ajuste conforme necessário)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mix_promocao

# URL pública da API (usada para callbacks OAuth e links gerados)
SITE_URL=https://sua-api.exemplo.com

# Origens permitidas (CSV) — incluir seu GitHub Pages, Cloud Run domain, etc.
ALLOWED_ORIGINS=https://seuuser.github.io,https://outra-origem.exemplo.com

# GitHub OAuth (opcional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP (envio de e-mails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Mix Promoção <no-reply@seu-dominio.com>

# PagBank / PagSeguro (se usar pagamentos)
PAGBANK_TOKEN_SANDBOX=
PAGBANK_TOKEN_PRODUCTION=
PAGBANK_NOTIFICATION_URL=

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
# ========================================
# MIX-PROMOÇÃO — Variáveis de Ambiente (EXEMPLO)
# Copie este arquivo para .env e preencha
# ========================================

NODE_ENV=sandbox
PORT=3000

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=mixpromocaodb

JWT_SECRET=TROQUE_POR_UMA_CHAVE_FORTE_ALEATORIA

PAGBANK_TOKEN_SANDBOX=SEU_TOKEN_SANDBOX
PAGBANK_TOKEN_PRODUCTION=SEU_TOKEN_PRODUCAO

PAGBANK_NOTIFICATION_URL=https://seusite.com/api/pagbank/notificacao

SITE_URL=http://localhost:3000

# --- Config para exportação via GitHub Action/script local
# Liste as tabelas a exportar (separadas por vírgula)
EXPORT_TABLES=produtos,clientes,pedidos,compras,comentarios
# Campos sensíveis a filtrar dos JSONs (fragmentos de nomes de colunas)
SENSITIVE_FIELDS=senha,password,token,secret,cpf
