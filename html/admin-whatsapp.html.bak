<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MIX-PROMOÇÃO - WhatsApp Promocional</title>

  <link rel="stylesheet" href="/src/public/css/style-index.css" />
  <link rel="stylesheet" href="/src/public/css/menu.css" />
  <link rel="stylesheet" href="/src/public/css/logo.css" />
  <link rel="stylesheet" href="/src/public/css/statusLogin.css" />
  <link rel="stylesheet" href="/src/public/css/minhaConta.css" />
  <link rel="stylesheet" href="/src/public/css/btn-topo.css" />
  <link rel="stylesheet" href="/src/public/css/footer.css" />
  <link rel="stylesheet" href="/src/public/css/admin-whatsapp.css" />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body>
  <header class="site-header">
    <div class="logo">
      <span class="logo-icon">🛒</span>
      <span class="logo-text">
        <span class="mix">MIX</span><span class="promocao">PROMOÇÃO</span>
      </span>
    </div>

    <nav class="menu" aria-label="Menu principal">
      <ul>
        <li><a href="index.html"><i class="fa-solid fa-house menu-link-icon" aria-hidden="true"></i><span>Início</span></a></li>
        <li><a href="loja.html"><i class="fa-solid fa-store menu-link-icon" aria-hidden="true"></i><span>Nossa Loja</span></a></li>
        <li><a href="QuemSomos.html"><i class="fa-solid fa-circle-info menu-link-icon" aria-hidden="true"></i><span>Sobre</span></a></li>
        
        <li><a href="trocas-devolucoes.html"><i class="fa-solid fa-right-left menu-link-icon" aria-hidden="true"></i><span>Trocas e Devoluções</span></a></li>
        <li><a href="ajuda.html"><i class="fa-solid fa-circle-question menu-link-icon" aria-hidden="true"></i><span>Ajuda</span></a></li>
      </ul>
    </nav>

    <div id="loginButtons">
      <a href="login-cliente.html" class="btn-login cliente">👤 Login Cliente</a>
      <a href="admin-login.html" class="btn-login admin">👤 Login Administrativo</a>
    </div>

    <div id="statusLogado" class="status-admin" style="display:none;">
      <span class="status-text">👑 Administrador: <strong id="nomeUsuario"></strong></span>
      <button id="logout" class="btn-logout">Sair</button>
    </div>

    <div id="clienteStatus" style="display:none;">
      <img id="fotoCliente" class="foto-perfil" src="" alt="Foto Cliente">
      <span id="nomeCliente"></span>
      <span id="sobrenomeCliente"></span>
      <button id="btnMinhaConta" class="btn-minha-conta">👤 Minha Conta</button>
      <button id="logoutBtn" class="btn-logout">Sair</button>
    </div>
  </header>

  <main class="wpp-main">
    <!-- Hero -->
    <section class="wpp-hero">
      <div class="wpp-eyebrow">
        <i class="fab fa-whatsapp" aria-hidden="true"></i>
        <span>Marketing via WhatsApp</span>
      </div>
      <h1>WhatsApp Promocional</h1>
      <p>Crie mensagens de promoção e envie diretamente para seus clientes pelo WhatsApp. Selecione produtos, monte a mensagem e dispare!</p>
    </section>

    <!-- Gerador IA -->
    <section class="wpp-ia-gerador">
      <div class="wpp-ia-header">
        <div class="wpp-ia-titulo">
          <div class="wpp-ia-icone-pulse">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
          </div>
          <div>
            <h2>Assistente IA de Promoções</h2>
            <p>Selecione produtos e deixe a IA criar mensagens promocionais perfeitas para WhatsApp</p>
          </div>
        </div>
      </div>

      <div class="wpp-ia-conteudo">
        <!-- Seletor de Produtos -->
        <div class="wpp-ia-produtos-section">
          <label><i class="fa-solid fa-box"></i> Produtos da Loja</label>
          <div class="wpp-ia-busca-produto">
            <input type="text" id="wppIaBuscaProduto" placeholder="🔍 Buscar produto por nome...">
          </div>
          <div class="wpp-ia-produtos-lista" id="wppIaListaProdutos"></div>
          <div class="wpp-ia-selecionados" id="wppIaTagsSelecionados"></div>
        </div>

        <!-- Tom -->
        <div class="wpp-ia-opcoes">
          <div class="wpp-ia-opcao-grupo">
            <label><i class="fa-solid fa-palette"></i> Tom da Mensagem</label>
            <div class="wpp-ia-tom-btns">
              <button class="wpp-ia-tom-btn ativo" data-tom="urgente"><i class="fa-solid fa-fire"></i> Urgente</button>
              <button class="wpp-ia-tom-btn" data-tom="elegante"><i class="fa-solid fa-gem"></i> Elegante</button>
              <button class="wpp-ia-tom-btn" data-tom="divertido"><i class="fa-solid fa-face-laugh-beam"></i> Divertido</button>
              <button class="wpp-ia-tom-btn" data-tom="exclusivo"><i class="fa-solid fa-crown"></i> Exclusivo</button>
            </div>
          </div>

          <div class="wpp-ia-opcao-grupo">
            <label><i class="fa-solid fa-bullseye"></i> Tipo de Campanha</label>
            <div class="wpp-ia-tom-btns">
              <button class="wpp-ia-campanha-btn ativo" data-campanha="desconto"><i class="fa-solid fa-percent"></i> Desconto</button>
              <button class="wpp-ia-campanha-btn" data-campanha="lancamento"><i class="fa-solid fa-rocket"></i> Lançamento</button>
              <button class="wpp-ia-campanha-btn" data-campanha="frete"><i class="fa-solid fa-truck-fast"></i> Frete Grátis</button>
              <button class="wpp-ia-campanha-btn" data-campanha="flash"><i class="fa-solid fa-bolt"></i> Flash Sale</button>
            </div>
          </div>
        </div>

        <!-- Botão gerar -->
        <button class="wpp-ia-btn-gerar" id="wppBtnGerarIA">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          <span>Gerar Mensagem com IA</span>
        </button>

        <!-- Loading -->
        <div class="wpp-ia-loading" id="wppIaLoading" style="display:none;">
          <div class="wpp-ia-loading-spinner"></div>
          <div class="wpp-ia-loading-texto">
            <span id="wppIaLoadingMsg">Criando mensagem...</span>
          </div>
        </div>

        <!-- Resultado -->
        <div class="wpp-ia-resultado" id="wppIaResultado" style="display:none;">
          <div class="wpp-ia-resultado-header">
            <span><i class="fa-solid fa-sparkles"></i> Mensagem Gerada pela IA</span>
            <div class="wpp-ia-resultado-acoes">
              <button class="wpp-ia-btn-refazer" id="wppBtnRefazerIA" title="Gerar outra versão"><i class="fa-solid fa-rotate"></i></button>
              <button class="wpp-ia-btn-usar" id="wppBtnUsarIA"><i class="fa-solid fa-check"></i> Usar na Mensagem</button>
            </div>
          </div>
          <div class="wpp-ia-resultado-corpo" id="wppIaCorpoGerado"></div>
        </div>
      </div>
    </section>

    <div class="wpp-layout">
      <!-- Painel esquerdo: Destinatários -->
      <aside class="wpp-destinatarios">
        <div class="wpp-dest-header">
          <h2><i class="fa-solid fa-users"></i> Destinatários</h2>
          <div class="wpp-dest-acoes">
            <button class="wpp-btn-selecionar-todos" id="wppBtnSelecionarTodos">
              <i class="fa-solid fa-check-double"></i> Todos
            </button>
            <span class="wpp-dest-contagem" id="wppContagemSelecionados">0 selecionados</span>
          </div>
        </div>
        <input type="text" class="wpp-dest-busca" id="wppBuscaCliente" placeholder="🔍 Buscar cliente por nome ou telefone...">
        <div class="wpp-dest-lista" id="wppListaClientes">
          <p class="wpp-dest-carregando"><i class="fa-solid fa-spinner fa-spin"></i> Carregando clientes...</p>
        </div>
      </aside>

      <!-- Painel direito: Composição -->
      <section class="wpp-composer">
        <h2><i class="fab fa-whatsapp"></i> Compor Mensagem</h2>

        <!-- Destinatários selecionados -->
        <div class="wpp-composer-dest" id="wppComposerDest">
          <div class="wpp-composer-dest-header">
            <span><i class="fa-solid fa-users"></i> Destinatários</span>
            <span class="wpp-composer-dest-count" id="wppComposerDestCount">0</span>
          </div>
          <div class="wpp-composer-dest-add">
            <input type="tel" id="wppInputAddTelefone" placeholder="Digite um telefone com DDD e pressione Enter..." autocomplete="off">
            <button id="wppBtnAddTelefone" title="Adicionar telefone"><i class="fa-solid fa-plus"></i></button>
          </div>
          <div class="wpp-composer-dest-lista" id="wppComposerDestLista">
            <span class="wpp-composer-dest-vazio">Adicione destinatários acima ou selecione na lista ao lado.</span>
          </div>
          <div class="wpp-composer-dest-tags" id="wppComposerDestTags"></div>
        </div>

        <!-- Mídias dos Produtos -->
        <div class="wpp-campo-grupo">
          <label><i class="fa-solid fa-photo-film"></i> Imagens e Vídeos</label>
          <div class="wpp-upload-area" id="wppUploadArea">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <p>Clique ou arraste imagens e vídeos aqui <span>(máx. 5)</span></p>
            <input type="file" id="wppInputImagens" accept="image/*,video/*" multiple hidden>
          </div>
          <div class="wpp-imagens-preview" id="wppImagensPreview"></div>
          <p class="wpp-imagens-dica"><i class="fa-solid fa-circle-info"></i> Imagens e vídeos serão enviados separadamente antes da mensagem de texto no WhatsApp.</p>
        </div>

        <!-- Link da Loja -->
        <div class="wpp-campo-grupo">
          <label for="wppLinkLoja"><i class="fa-solid fa-link"></i> Link da Loja / Produto</label>
          <div class="wpp-link-grupo">
            <input type="url" id="wppLinkLoja" placeholder="https://seusite.com/loja" value="">
            <button type="button" id="wppBtnLinkPadrao" class="wpp-btn-link-padrao" title="Usar link padrão da loja"><i class="fa-solid fa-store"></i> Loja</button>
          </div>
          <p class="wpp-link-dica"><i class="fa-solid fa-mobile-screen"></i> O link será adicionado ao final da mensagem para o cliente acessar direto pelo celular.</p>
        </div>

        <!-- Logo MIX PROMOÇÃO -->
        <div class="wpp-campo-grupo wpp-logo-campo">
          <label><i class="fa-solid fa-image"></i> Logo na Mensagem</label>
          <div class="wpp-logo-toggle">
            <label class="wpp-switch">
              <input type="checkbox" id="wppLogoAtivo" checked>
              <span class="wpp-switch-slider"></span>
            </label>
            <span class="wpp-logo-toggle-text">Incluir logo MIX-PROMOÇÃO na mensagem</span>
          </div>
          <div class="wpp-logo-mini-preview" id="wppLogoMiniPreview">
            <canvas id="wppLogoCanvas" width="600" height="200"></canvas>
          </div>
        </div>

        <div class="wpp-campo-grupo">
          <label for="wppMensagem"><i class="fa-solid fa-comment-dots"></i> Mensagem Promocional</label>
          <textarea id="wppMensagem" rows="10" placeholder="Escreva a mensagem de promoção para enviar via WhatsApp...&#10;&#10;Dica: Use emojis 🔥🎉💰 para chamar atenção!"></textarea>
          <div class="wpp-char-count"><span id="wppCharCount">0</span> caracteres</div>
        </div>

        <!-- Preview -->
        <div class="wpp-preview-toggle">
          <button id="wppBtnPreview"><i class="fa-solid fa-eye"></i> Pré-visualizar Mensagem</button>
        </div>

        <div class="wpp-preview" id="wppPreview" style="display:none;">
          <div class="wpp-preview-header">
            <div class="wpp-preview-header-info">
              <div class="wpp-preview-avatar"><i class="fa-solid fa-store"></i></div>
              <div>
                <strong>MIX-PROMOÇÃO</strong>
                <span>online</span>
              </div>
            </div>
            <button id="wppFecharPreview">&times;</button>
          </div>
          <div class="wpp-preview-chat">
            <div class="wpp-preview-bg"></div>
            <div class="wpp-preview-logo" id="wppPreviewLogo" style="display:none"></div>
            <div class="wpp-preview-imagens" id="wppPreviewImagens"></div>
            <div class="wpp-preview-balao" id="wppPreviewBalao">
              <p id="wppPreviewTexto"></p>
              <span class="wpp-preview-hora"></span>
            </div>
          </div>
        </div>

        <!-- Botões enviar -->
        <div class="wpp-enviar-grupo">
          <button class="wpp-btn-enviar" id="wppBtnEnviar">
            <i class="fab fa-whatsapp"></i> Enviar via WhatsApp
          </button>
          <button class="wpp-btn-enviar-imagens" id="wppBtnEnviarImagens" style="display:none">
            <i class="fa-solid fa-photo-film"></i> Enviar Mídias Primeiro
          </button>
        </div>

        <p class="wpp-status" id="wppStatus"></p>
      </section>
    </div>

    <!-- Histórico -->
    <section class="wpp-historico">
      <h2><i class="fa-solid fa-clock-rotate-left"></i> Mensagens Enviadas</h2>
      <div id="wppListaHistorico">
        <p class="wpp-historico-vazio" id="wppMsgHistoricoVazio">Nenhuma mensagem enviada ainda.</p>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-top-bar"></div>
    <div class="footer-main">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="footer-logo-icon">🛒</span>
          <span class="footer-logo-text"><span class="mix">MIX</span><span class="promo">PROMOÇÃO</span></span>
        </div>
        <p class="footer-desc">Oferecemos os melhores produtos com qualidade e preço justo. Promoções exclusivas e ofertas imperdíveis todos os dias!</p>
        <div class="footer-social">
          <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="#" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
          <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
        </div>
      </div>
      <div class="footer-links">
        <h4>Navegação</h4>
        <ul>
          <li><a href="index.html"><i class="fa-solid fa-chevron-right"></i> Início</a></li>
          <li><a href="loja.html"><i class="fa-solid fa-chevron-right"></i> Nossa Loja</a></li>
          <li><a href="QuemSomos.html"><i class="fa-solid fa-chevron-right"></i> Sobre Nós</a></li>
          
        </ul>
      </div>
      <div class="footer-links suporte">
        <h4>Suporte</h4>
        <ul>
          <li><a href="trocas-devolucoes.html"><i class="fa-solid fa-chevron-right"></i> Trocas e Devoluções</a></li>
          <li><a href="carrinho.html"><i class="fa-solid fa-chevron-right"></i> Meu Carrinho</a></li>
        </ul>
      </div>
      <!-- Contato removido -->
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <p>&copy; 2026 MIX-PROMOÇÃO. Todos os direitos reservados.</p>
        <div class="footer-links">
        <!-- Contato removido -->
          </div>
        </div>
      </div>
    </div>
  </div>

  </footer>

  <!-- SCRIPTS -->
  <script src="/src/public/js/statusLogin.js"></script>
  <script src="/src/public/js/admin-whatsapp.js"></script>
</body>
</html>

