<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MIX-PROMOÇÃO - Checkout</title>

  <!-- CSS reaproveitado -->
  <link rel="stylesheet" href="/src/public/css/style-index.css" />
  <link rel="stylesheet" href="/src/public/css/checkout.css" />
  <link rel="stylesheet" href="/src/public/css/bannerpromo.css" />
  <link rel="stylesheet" href="/src/public/css/menu.css" />
  <link rel="stylesheet" href="/src/public/css/carrinho.css" />
  <link rel="stylesheet" href="/src/public/css/logo.css" />
  <link rel="stylesheet" href="/src/public/css/minhaConta.css" />
  <link rel="stylesheet" href="/src/public/css/statusLogin.css" />
  <link rel="stylesheet" href="/src/public/css/popup-bloqueio.css" />
  <link rel="stylesheet" href="/src/public/css/btn-topo.css" />
  <link rel="stylesheet" href="/src/public/css/footer.css" />

  <!-- Ícones Font Awesome -->
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/src/public/css/chatbot-widget.css" />

  <!-- PagBank SDK para encriptar cartão -->
  <script src="https://assets.pagseguro.com.br/checkout-sdk-js/rc/dist/browser/pagseguro.min.js"></script>
</head>
<body>
  <!-- Cabeçalho -->
  <header class="site-header">
    <div class="logo">
      <span class="logo-icon">🛒</span>
      <span class="logo-text">
        <span class="mix">MIX</span><span class="promocao">PROMOÇÃO</span>
      </span>
    </div> 

    <!-- Menu -->
    <nav class="menu" aria-label="Menu principal">
      <ul>
        <li><a href="index.html" class="active"><i class="fa-solid fa-house menu-link-icon" aria-hidden="true"></i><span>Início</span></a></li>
        <li><a href="loja.html"><i class="fa-solid fa-store menu-link-icon" aria-hidden="true"></i><span>Nossa Loja</span></a></li>
        <li><a href="QuemSomos.html"><i class="fa-solid fa-circle-info menu-link-icon" aria-hidden="true"></i><span>Sobre</span></a></li>
        
        <li><a href="trocas-devolucoes.html"><i class="fa-solid fa-right-left menu-link-icon" aria-hidden="true"></i><span>Trocas e Devoluções</span></a></li>
        <li><a href="ajuda.html"><i class="fa-solid fa-circle-question menu-link-icon" aria-hidden="true"></i><span>Ajuda</span></a></li>
      </ul>
    </nav>

   <!-- Botões de login -->
    <div id="loginButtons">
      <a href="login-cliente.html" class="btn-login cliente">👤 Login Cliente</a>
      <a href="admin-login.html" class="btn-login admin">👤 Login Administrativo</a>
    </div>

    <!-- Status de login administrador -->
    <div id="statusLogado" class="status-admin" style="display:none;">
      <span class="status-text">👑 Administrador: <strong id="nomeUsuario"></strong></span>
      <button id="logout" class="btn-logout">Sair</button>
    </div>

    <!-- Status de login cliente -->
    <div id="clienteStatus" style="display:none;">
  <img id="fotoCliente" class="foto-perfil" src="" alt="Foto Cliente">
  <span id="nomeCliente"></span>
  <span id="sobrenomeCliente"></span>
  
  <!-- Botão Minha Conta -->
  <button id="btnMinhaConta" class="btn-minha-conta">👤 Minha Conta</button>

  <!-- Botão Sair -->
  <button id="logoutBtn" class="btn-logout">Sair</button>
</div>


   


    <!-- Ícone do carrinho -->
    <a href="carrinho.html" class="cart-icon" aria-label="Carrinho de Compras">
      <i class="fas fa-shopping-cart"></i>
      <span id="cart-count">0</span>
    </a>
  </header>

  <!-- Banner frete -->
  <div class="banner-frete">
    <span class="icon">🚚🛒</span>
    <span class="texto">Frete Grátis em compras acima de R$ 100,00!</span>
  </div>

  <!-- Breadcrumb -->
  <div class="checkout-breadcrumb">
    <a href="carrinho.html"><i class="fa-solid fa-arrow-left"></i> Voltar ao carrinho</a>
    <span>Início / Carrinho / <strong>Checkout</strong></span>
  </div>

  <!-- Steps -->
  <div class="checkout-steps">
    <div class="checkout-step active" data-step="1">
      <div class="step-circle"><i class="fa-solid fa-location-dot"></i></div>
      <span>Endereço</span>
    </div>
    <div class="step-line active"></div>
    <div class="checkout-step" data-step="2">
      <div class="step-circle"><i class="fa-solid fa-credit-card"></i></div>
      <span>Pagamento</span>
    </div>
    <div class="step-line"></div>
    <div class="checkout-step" data-step="3">
      <div class="step-circle"><i class="fa-solid fa-check"></i></div>
      <span>Confirmação</span>
    </div>
  </div>

  <!-- Layout Principal -->
  <div class="checkout-layout">

    <!-- Coluna Esquerda: Formulário -->
    <div class="checkout-form-area">

      <!-- Alerta de teste -->
      <div class="checkout-alerta-teste" id="checkoutAreaTeste">
        <div class="alerta-teste-icon"><i class="fa-solid fa-flask"></i></div>
        <div class="alerta-teste-content">
          <strong>Modo de teste</strong>
          <p>Ambiente local — use os botões para preencher dados de demonstração.</p>
        </div>
        <div class="checkout-alerta-acoes">
          <button type="button" class="btn-teste" id="btnPreencherTeste"><i class="fa-solid fa-wand-magic-sparkles"></i> Preencher teste</button>
          <button type="button" class="btn-teste btn-teste-secundario" id="btnGerarPedidoTeste"><i class="fa-solid fa-bolt"></i> Gerar pedido</button>
        </div>
      </div>

      <form id="checkoutForm">

        <!-- Seção 1: Endereço de Entrega -->
        <div class="checkout-section" id="secaoEndereco">
          <div class="section-header">
            <div class="section-icon"><i class="fa-solid fa-truck-fast"></i></div>
            <div>
              <h3>Endereço de Entrega</h3>
              <p>Para onde devemos enviar seu pedido?</p>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group form-group-large">
              <label for="rua"><i class="fa-solid fa-road"></i> Rua / Avenida</label>
              <input type="text" id="rua" placeholder="Ex: Rua das Flores" required>
            </div>
            <div class="form-group form-group-small">
              <label for="numero"><i class="fa-solid fa-hashtag"></i> Número</label>
              <input type="text" id="numero" placeholder="123" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="bairro"><i class="fa-solid fa-map-pin"></i> Bairro</label>
              <input type="text" id="bairro" placeholder="Ex: Centro" required>
            </div>
            <div class="form-group">
              <label for="complemento"><i class="fa-solid fa-building"></i> Complemento</label>
              <input type="text" id="complemento" placeholder="Apto, Bloco, etc.">
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="estado"><i class="fa-solid fa-flag"></i> Estado</label>
              <input type="text" id="estado" placeholder="Ex: RJ" required>
            </div>
            <div class="form-group">
              <label for="cep"><i class="fa-solid fa-location-dot"></i> CEP</label>
              <input type="text" id="cep" placeholder="00000-000" maxlength="9" required>
            </div>
            <div class="form-group">
              <label for="telefone"><i class="fa-solid fa-phone"></i> Telefone</label>
              <input type="tel" id="telefone" placeholder="(21) 99999-9999" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email"><i class="fa-solid fa-envelope"></i> E-mail</label>
              <input type="email" id="email" placeholder="seuemail@exemplo.com" required>
            </div>
            <div class="form-group">
              <label for="cpf"><i class="fa-solid fa-id-card"></i> CPF</label>
              <input type="text" id="cpf" placeholder="000.000.000-00" maxlength="14" required>
            </div>
          </div>

          <button type="button" class="btn-avancar" id="btnAvancarPagamento">
            Continuar para Pagamento <i class="fa-solid fa-arrow-right"></i>
          </button>
        </div>

        <!-- Seção 2: Pagamento -->
        <div class="checkout-section checkout-section-hidden" id="secaoPagamento">
          <div class="section-header">
            <div class="section-icon section-icon-pagamento"><i class="fa-solid fa-shield-halved"></i></div>
            <div>
              <h3>Forma de Pagamento</h3>
              <p>Escolha como deseja pagar — seus dados estão seguros.</p>
            </div>
          </div>

          <div class="pagamento-opcoes">
            <label class="pagamento-card" data-valor="pix">
              <input type="radio" name="pagamentoTipo" value="pix" checked>
              <div class="pagamento-card-inner">
                <i class="fa-brands fa-pix"></i>
                <span>PIX</span>
              </div>
            </label>
            <label class="pagamento-card" data-valor="boleto">
              <input type="radio" name="pagamentoTipo" value="boleto">
              <div class="pagamento-card-inner">
                <i class="fa-solid fa-barcode"></i>
                <span>Boleto</span>
              </div>
            </label>
            <label class="pagamento-card" data-valor="credito">
              <input type="radio" name="pagamentoTipo" value="credito">
              <div class="pagamento-card-inner">
                <i class="fa-solid fa-credit-card"></i>
                <span>Crédito</span>
              </div>
            </label>
            <label class="pagamento-card" data-valor="debito">
              <input type="radio" name="pagamentoTipo" value="debito">
              <div class="pagamento-card-inner">
                <i class="fa-solid fa-credit-card"></i>
                <span>Débito</span>
              </div>
            </label>
            <label class="pagamento-card" data-valor="pix">
              <input type="radio" name="pagamentoTipo" value="pix">
              <div class="pagamento-card-inner">
                <i class="fa-brands fa-pix"></i>
                <span>PIX</span>
              </div>
            </label>
            <label class="pagamento-card" data-valor="boleto">
              <input type="radio" name="pagamentoTipo" value="boleto">
              <div class="pagamento-card-inner">
                <i class="fa-solid fa-barcode"></i>
                <span>Boleto</span>
              </div>
            </label>
          </div>

          <!-- Select hidden para compatibilidade com JS existente -->
          <select id="pagamento" required style="display:none;">
            <option value="">Selecione...</option>
            <option value="credito">Cartão de Crédito</option>
            <option value="debito">Cartão de Débito</option>
            <option value="pix">PIX</option>
            <option value="boleto">Boleto Bancário</option>
          </select>

          <!-- Campos extras para cartão -->
          <div id="cartaoCampos" class="cartao-campos-pro" style="display:none;">
            <div class="cartao-visual">
              <div class="cartao-preview" id="cartaoPreview">
                <!-- Decoração visual do banco (SVG patterns) -->
                <div class="cartao-deco" id="cartaoDeco"></div>

                <div class="cartao-topo">
                  <div class="cartao-chip">
                    <div class="chip-linha"></div>
                    <div class="chip-linha"></div>
                    <div class="chip-linha"></div>
                  </div>
                  <div class="cartao-topo-direita">
                    <span class="cartao-banco-nome" id="cartaoBancoNome"></span>
                    <div class="cartao-bandeira" id="cartaoBandeira">
                      <i class="fa-solid fa-credit-card"></i>
                    </div>
                  </div>
                </div>

                <div class="cartao-contactless">
                  <i class="fa-solid fa-wifi"></i>
                </div>

                <div class="cartao-numero-preview">•••• •••• •••• ••••</div>

                <div class="cartao-info-preview">
                  <div class="cartao-info-bloco">
                    <span class="cartao-label-mini">TITULAR</span>
                    <span class="cartao-nome-preview">SEU NOME</span>
                  </div>
                  <div class="cartao-info-bloco cartao-info-bloco-right">
                    <span class="cartao-label-mini">VALIDADE</span>
                    <span class="cartao-val-preview">MM/AA</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group form-group-full">
                <label for="nomeTitular"><i class="fa-solid fa-user"></i> Nome no Cartão</label>
                <input type="text" id="nomeTitular" placeholder="Nome como está no cartão" autocomplete="cc-name">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group form-group-full">
                <label for="numeroCartao"><i class="fa-solid fa-lock"></i> Número do Cartão</label>
                <input type="text" id="numeroCartao" placeholder="0000 0000 0000 0000" maxlength="19" autocomplete="cc-number">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="validade"><i class="fa-regular fa-calendar"></i> Validade</label>
                <input type="text" id="validade" placeholder="MM/AA" maxlength="5" autocomplete="cc-exp">
              </div>
              <div class="form-group">
                <label for="cvv"><i class="fa-solid fa-shield"></i> CVV</label>
                <input type="text" id="cvv" placeholder="123" maxlength="4" autocomplete="cc-csc">
              </div>
            </div>
          </div>

          <div class="btns-navegacao">
            <button type="button" class="btn-voltar-step" id="btnVoltarEndereco">
              <i class="fa-solid fa-arrow-left"></i> Voltar
            </button>
            <button type="submit" class="btn-confirmar-pedido" id="btnConfirmarPedido">
              <i class="fa-solid fa-lock"></i> Confirmar Pedido
            </button>
          </div>

          <!-- Selos de segurança -->
          <div class="checkout-seguranca">
            <div class="selo"><i class="fa-solid fa-lock"></i> Pagamento Seguro</div>
            <div class="selo"><i class="fa-solid fa-shield-halved"></i> Dados Protegidos</div>
            <div class="selo"><i class="fa-solid fa-rotate-left"></i> Devolução Garantida</div>
          </div>
        </div>

      </form>

      <div id="checkoutMensagem" class="checkout-mensagem" aria-live="polite"></div>
      <span id="checkoutAmbiente" style="display:none;"></span>
    </div>

    <!-- Coluna Direita: Resumo do Pedido (Sidebar) -->
    <aside class="checkout-sidebar">
      <div class="sidebar-card sidebar-resumo">
        <div class="sidebar-header">
          <h4><i class="fa-solid fa-bag-shopping"></i> Resumo do Pedido</h4>
          <span class="sidebar-badge" id="sidebarQtd">0 itens</span>
        </div>
        <ul id="checkoutListaItens" class="sidebar-itens-lista"></ul>

        <div class="sidebar-divider"></div>

        <div class="sidebar-totais">
          <div class="sidebar-linha">
            <span>Subtotal</span>
            <span id="sidebarSubtotal">R$ 0,00</span>
          </div>
          <div class="sidebar-linha">
            <span>Frete</span>
            <span id="resumoFreteCheckout" class="sidebar-frete">-</span>
          </div>
          <div class="sidebar-linha sidebar-desconto" id="sidebarDescontoLinha" style="display:none;">
            <span>Desconto</span>
            <span class="valor-desconto">- R$ 0,00</span>
          </div>
          <div class="sidebar-divider"></div>
          <div class="sidebar-linha sidebar-total">
            <span>Total</span>
            <strong>R$ <span id="totalResumo">0,00</span></strong>
          </div>
        </div>
      </div>

      <!-- Card frete grátis -->
      <div class="sidebar-card sidebar-frete-msg" id="sidebarFreteMsgCard">
        <i class="fa-solid fa-truck-fast"></i>
        <span>Frete grátis em compras acima de <strong>R$ 100,00</strong></span>
      </div>

      <!-- Card segurança -->
      <div class="sidebar-card sidebar-trust">
        <div class="trust-item"><i class="fa-solid fa-shield-halved"></i> Compra 100% segura</div>
        <div class="trust-item"><i class="fa-solid fa-truck-fast"></i> Entrega garantida</div>
        <div class="trust-item"><i class="fa-solid fa-headset"></i> Suporte dedicado</div>
      </div>

      <!-- Pagamentos aceitos -->
      <div class="sidebar-card sidebar-pagamentos">
        <span class="sidebar-pagamentos-label">Pagamentos aceitos</span>
        <div class="sidebar-pagamentos-icons">
          <i class="fab fa-cc-visa"></i>
          <i class="fab fa-cc-mastercard"></i>
          <i class="fab fa-pix"></i>
          <i class="fa-solid fa-barcode"></i>
        </div>
      </div>
    </aside>

  </div>

  <!-- Rodapé -->
  <footer class="site-footer">
    <div class="footer-top-bar"></div>
    <div class="footer-main">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="footer-logo-icon">🛒</span>
          <span class="footer-logo-text"><span class="mix">MIX</span><span class="promo">PROMOÇÃO</span></span>
        </div>
        <p class="footer-desc">Oferecemos os melhores produtos com qualidade e preço justo. Promoções exclusivas e ofertas imperdíveis todos os dias!</p>
        <div class="footer-social">
          <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="#" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
          <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
        </div>
      </div>
      <div class="footer-links">
        <h4>Navegação</h4>
        <ul>
          <li><a href="index.html"><i class="fa-solid fa-chevron-right"></i> Início</a></li>
          <li><a href="loja.html"><i class="fa-solid fa-chevron-right"></i> Nossa Loja</a></li>
          <li><a href="QuemSomos.html"><i class="fa-solid fa-chevron-right"></i> Sobre Nós</a></li>
        </ul>
      </div>
      <div class="footer-links suporte">
        <h4>Suporte</h4>
        <ul>
          <li><a href="trocas-devolucoes.html"><i class="fa-solid fa-chevron-right"></i> Trocas e Devoluções</a></li>
          <li><a href="carrinho.html"><i class="fa-solid fa-chevron-right"></i> Meu Carrinho</a></li>
        </ul>
      </div>
      <!-- Contato removido -->
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <p>&copy; 2026 MIX-PROMOÇÃO. Todos os direitos reservados.</p>
        <div class="footer-pagamentos">
          <span>Pagamentos:</span>
          <i class="fab fa-cc-visa"></i>
          <i class="fab fa-cc-mastercard"></i>
          <i class="fab fa-pix"></i>
          <i class="fa-solid fa-barcode"></i>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="/src/public/js/carrinho.js"></script>
  <script src="/src/public/js/frete.js"></script>
  <script src="/src/public/js/carrossel.js"></script>
  <script src="/src/public/js/upload-foto.js"></script>
  <script src="/src/public/js/login-Admin.js"></script>
  <script src="/src/public/js/statusLogin.js"></script>
  <script src="/src/public/js/logo.js"></script>
  <script src="/src/public/js/bloqueio-checkout.js"></script>
  <script src="/src/public/js/checkout-resumo-frete.js"></script>
  <script src="/src/public/js/checkout-total.js"></script>
  <script src="/src/public/js/pagamento-personalizado.js"></script>
  <script src="/src/public/js/pagbank.js"></script>
  <script src="/src/public/js/checkout-pedidos.js"></script>
  <script src="/src/public/js/checkout-steps.js"></script>
  <script src="/src/public/js/btn-topo.js"></script>
  <script src="/src/public/js/bloquear-copia.js"></script>
  <script src="/src/public/js/chatbot-widget.js"></script>
</body>
</body>

</html>