# ========================================
# MIX-PROMOÇÃO — Variáveis de Ambiente
# ========================================


# Ambiente: "sandbox" para testes, "production" para produção
NODE_ENV=sandbox

# Porta do servidor
PORT=3000

# ========================================
# BANCO DE DADOS MYSQL
# ========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mix_promocao

# ========================================
# JWT (autenticação)
# ========================================
JWT_SECRET=minha_chave_secreta_super_segura

# ========================================
# PAGBANK
# ========================================

# Token Sandbox (teste)
PAGBANK_TOKEN_SANDBOX=c83372fe-e3dc-4af5-8c2d-5c0290d5f67b4dc867b8431d8373dc473f455ff4d6b4bbae-035a-4a55-8d25-494560002cef
# Token Produção (preencha quando for para produção)
PAGBANK_TOKEN_PRODUCTION=

# URL de notificação (webhook) — use localhost para testes
PAGBANK_NOTIFICATION_URL=http://localhost:3000/api/pagbank/notificacao

# ========================================
# DOMÍNIO DA LOJA (para CORS em produção)
# ========================================
SITE_URL=http://localhost:3000
