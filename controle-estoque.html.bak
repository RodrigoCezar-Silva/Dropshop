<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Controle de Estoque - Admin</title>
 
  <link rel="stylesheet" href="/src/public/css/controle-estoque-pro.css">
  <link rel="stylesheet" href="/src/public/css/style-vitrine.css">
</head>
<body>
  <div class="estoque-pro-container">
    <div class="estoque-pro-header-area">
      <div class="estoque-pro-header-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
      <div>
        <h1 class="estoque-pro-title">Controle de Estoque</h1>
        <p class="estoque-pro-desc">Gerencie o estoque dos produtos cadastrados na loja de forma prática e visual. Remova produtos, veja detalhes e mantenha o controle atualizado.</p>
        <a href="/src/public/html/admin-area.html" class="estoque-pro-back-admin"><i class="fa-solid fa-arrow-left"></i> Voltar para Área Admin</a>
      </div>
    </div>
    <div class="estoque-pro-toolbar">
      <span class="estoque-pro-toolbar-info"><i class="fa-solid fa-warehouse"></i> Produtos em estoque: <span id="estoque-pro-contador">0</span></span>
      <a href="/src/public/html/loja.html" class="estoque-pro-toolbar-btn"><i class="fa-solid fa-plus"></i> Novo Produto</a>
    </div>
    <table class="estoque-pro-table">
      <thead>
        <tr>
          <th>Imagem</th>
          <th>Nome</th>
          <th>Preço</th>
          <th>Quantidade</th>
          <th>Data de Postagem</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody id="estoque-pro-tbody">
        <!-- Produtos renderizados por JS -->
      </tbody>
    </table>
  </div>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  
  <script src="/src/public/js/controle-estoque.js"></script>
</body>
</html>
